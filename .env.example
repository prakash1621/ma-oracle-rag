# SEC EDGAR (required — must include contact email)
SEC_USER_AGENT=MAOracle your_email@example.com

# AWS Credentials (required if using bedrock embeddings)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_DEFAULT_REGION=us-east-1

# Provider overrides (optional — defaults come from config.yaml)
# EMBEDDING_PROVIDER=huggingface
