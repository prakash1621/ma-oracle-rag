# ============================================
# SEC EDGAR (required — must include contact email)
# ============================================
SEC_USER_AGENT=MAOracle your_email@example.com

# ============================================
# AWS Credentials (required if using bedrock embeddings)
# ============================================
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_DEFAULT_REGION=us-east-1

# ============================================
# Pinecone (required — shared with ingestion + NL2SQL memory)
# ============================================
PINECONE_API_KEY=your_pinecone_api_key

# ============================================
# Groq LLM (required — used by NL2SQL and RAG pipeline)
# ============================================
# Get your free key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# ============================================
# OpenAI (optional — only if using OpenAI as LLM provider)
# ============================================
# OPENAI_API_KEY=your_openai_api_key

# ============================================
# Provider overrides (optional — defaults come from config.yaml)
# ============================================
# EMBEDDING_PROVIDER=huggingface
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# ============================================
# Neo4j (required for Person 3 — Knowledge Graph)
# ============================================
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_neo4j_password
